# Riot Games API
# Get a development key at https://developer.riotgames.com (expires every 24h)
RIOT_API_KEY=RGAPI-your-key-here

# Routing — see https://developer.riotgames.com/docs/lol#routing-values
# Phase 1: BR1 + KR only
LOL_PLATFORMS=BR1,KR
LOL_REGIONS=AMERICAS,ASIA  # routing region for match-v5 endpoint

# Rate limiting (development key defaults)
RIOT_RATE_LIMIT_PER_SECOND=20
RIOT_RATE_LIMIT_PER_2MIN=100

# Storage paths (Databricks DBFS or local for dev)
BRONZE_PATH=/Volumes/main/lol/bronze
SILVER_PATH=/Volumes/main/lol/silver
GOLD_PATH=/Volumes/main/lol/gold

# Logging
LOG_LEVEL=INFO
